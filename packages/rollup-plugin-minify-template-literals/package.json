    "vite",
    "lit",
    "lit-html",
    "lit-element",
    "literals",
    "minify",
    "minification",
    "css",
    "html",
    "template-literals"
  ],
  "homepage": "https://github.com/explodingcamera/esm/tree/main/packages/rollup-plugin-minify-template-literals",
