  "license": "MIT",
  "author": "Henry Gressmann <npm@henrygressmann.de>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
